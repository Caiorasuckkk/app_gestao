# ============================================================
# Harmoni Care — Web (apps/web)
# Copie para .env.local e preencha com os valores do Supabase.
# NUNCA commite .env.local nem valores reais.
# ============================================================

# Supabase — variáveis PÚBLICAS (vão ao bundle do browser)
# Obtidas em: Supabase Dashboard → Project Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://<project-ref>.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=<anon-public-key>

# Supabase — chave SECRETA (somente servidor — NUNCA prefixar com NEXT_PUBLIC_)
# Usada apenas em route handlers / server actions privilegiadas.
# Obtida em: Supabase Dashboard → Project Settings → API → service_role key
SUPABASE_SERVICE_ROLE_KEY=<service-role-secret-key>
